project_name = "hybrid-ai-private"

private_network_cidr = "10.42.0.0/24"
dns_nameservers      = ["1.1.1.1", "8.8.8.8"]
ssh_allowed_cidrs    = ["203.0.113.0/24"]

# Set this only when the private network must egress through an OpenStack router.
external_network_id = ""

# Set these when bootstrap automation needs SSH access from outside the private subnet.
floating_ip_pool    = ""
assign_floating_ips = false

key_pair_name  = "hybrid-ai-private-admin"
ssh_public_key = "ssh-ed25519 REPLACE_WITH_PUBLIC_KEY_ONLY"

control_plane_count       = 1
control_plane_image_name  = "ubuntu-22.04"
control_plane_flavor_name = "m1.medium"

build_worker_count       = 1
build_worker_image_name  = "ubuntu-22.04"
build_worker_flavor_name = "m1.large"

gpu_worker_count       = 1
gpu_worker_image_name  = "ubuntu-22.04"
gpu_worker_flavor_name = "g1.large"

gitlab_count       = 1
gitlab_image_name  = "ubuntu-22.04"
gitlab_flavor_name = "m1.large"

# Keep empty unless a host reverse proxy must reach the GitLab VM directly over HTTP.
gitlab_http_allowed_cidrs = []

# Cloud-init installs common Kubernetes, storage, diagnostics, and GPU host dependencies.
install_node_dependencies = true
enable_gpu_bootstrap      = true
gpu_driver_autoinstall    = true
enable_gpu_cuda_bootstrap = true
gpu_cuda_toolkit_package  = "cuda-toolkit-12-1"
gpu_cudnn_package         = "cudnn9-cuda-12"

# GPU workers also prepare a Python environment for the feature/model training code.
enable_gpu_training_bootstrap        = true
gpu_training_venv_path               = "/opt/hybrid-ai/training-venv"
gpu_training_pytorch_cuda_index_url  = "https://download.pytorch.org/whl/cu121"
gpu_training_pip_cache_dir           = "/mnt/nfs/hybrid-ai/pip-cache"
gpu_training_python_packages = [
  "torch==2.1.0+cu121",
  "torchvision==0.16.0+cu121",
  "torchaudio==2.1.0+cu121",
  "numpy==1.26.4",
  "pandas==2.2.2",
  "scipy==1.11.4",
  "scikit-learn==1.4.2",
  "matplotlib==3.8.4",
  "seaborn==0.13.2",
  "notebook==7.2.2",
  "ipykernel==6.29.5",
  "minio==7.2.8",
]
