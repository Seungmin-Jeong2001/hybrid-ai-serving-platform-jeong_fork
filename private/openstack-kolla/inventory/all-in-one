# Kolla-Ansible single-node inventory (hybrid-ai "우리 서버")
# control / network / compute / storage / monitoring 전부 localhost
# 멀티노드 전환 시 kolla-ansible multinode 템플릿 참고

[control]
localhost ansible_connection=local

[network]
localhost ansible_connection=local

[compute]
localhost ansible_connection=local

[monitoring]
localhost ansible_connection=local

[storage]
localhost ansible_connection=local

[deployment]
localhost ansible_connection=local

# --- 그룹 롤업 (kolla-ansible 표준) ---
[baremetal:children]
control
network
compute
storage
monitoring

[openstack:children]
control
network
compute
storage
monitoring

[loadbalancer:children]
network

[nova-compute:children]
compute

[neutron:children]
network

[keystone:children]
control

[glance:children]
control

[placement:children]
control

[horizon:children]
control
