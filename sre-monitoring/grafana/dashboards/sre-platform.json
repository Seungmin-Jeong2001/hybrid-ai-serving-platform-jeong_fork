{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SRE 기반 비동기 AI 서빙 플랫폼 통합 모니터링 | 담당: 신민석",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "type": "row", "title": "🔑 플랫폼 핵심 지표", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 80 },

    { "id": 81, "title": "서비스 가용성",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.99 }, { "color": "green", "value": 0.999 }] },
          "mappings": [{ "type": "value", "options": { "1": { "text": "100%", "color": "green" } } }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "expr": "slo:service_availability:ratio", "legendFormat": "가용성", "refId": "A" }]
    },

    { "id": 82, "title": "🚨 Critical 알림",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "text": { "valueSize": 48 } },
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\",severity=\"critical\"}) or vector(0)", "legendFormat": "", "refId": "A" }]
    },

    { "id": 83, "title": "⚠️ Warning 알림",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "text": { "valueSize": 48 } },
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\",severity=\"warning\"}) or vector(0)", "legendFormat": "", "refId": "A" }]
    },

    { "id": 84, "title": "Error Budget 잔여",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.2 }, { "color": "green", "value": 0.5 }] },
          "mappings": [{ "type": "value", "options": { "1": { "text": "100%", "color": "green" } } }]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "expr": "slo:error_budget_remaining:ratio", "legendFormat": "잔여", "refId": "A" }]
    },

    { "id": 85, "title": "Running Pods",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value", "text": { "valueSize": 48 } },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "", "refId": "A" }]
    },

    { "id": 86, "title": "Ready 노드",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "text": { "valueSize": 48 } },
      "targets": [
        { "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "legendFormat": "", "refId": "A" }
      ]
    },

    { "type": "row", "title": "🎯 SLO / Error Budget 현황", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "id": 1 },

    {
      "id": 4, "title": "Error Budget 번 레이트 (1h / 6h / 24h)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "slo:error_budget_burn_rate:1h", "legendFormat": "1h 번 레이트", "refId": "A" },
        { "expr": "slo:error_budget_burn_rate:6h", "legendFormat": "6h 번 레이트", "refId": "B" },
        { "expr": "slo:error_budget_burn_rate:24h", "legendFormat": "24h 번 레이트", "refId": "C" },
        { "expr": "vector(14.4)", "legendFormat": "Critical 임계값 (1h 소진)", "refId": "D" },
        { "expr": "vector(6)", "legendFormat": "Warning 임계값 (6h 소진)", "refId": "E" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical 임계값 (1h 소진)" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
                           { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Warning 임계값 (6h 소진)" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
                           { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "title": "Service SLI - API Boundary (Latency / Availability / Errors / TPS)", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }, "id": 70 },

    { "id": 72, "title": "API P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "fixedColor": "#73BF69", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(istio_request_duration_milliseconds_bucket{destination_service=~\"inference-api.*\"}[5m])) by (le))", "legendFormat": "API P95 (Istio)", "refId": "A" }
      ]
    },

    { "id": 71, "title": "API P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "fixedColor": "#FF9900", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 3000 }, { "color": "red", "value": 5000 }] }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(istio_request_duration_milliseconds_bucket{destination_service=~\"inference-api.*\"}[5m])) by (le))", "legendFormat": "API P99 (Istio)", "refId": "A" },
        { "expr": "slo:http_latency_p99:5m * 1000", "legendFormat": "P99 SLO target", "refId": "B" }
      ]
    },

    { "id": 73, "title": "Workload Availability",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.5 },
            { "color": "green", "value": 0.99 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "minVizWidth": 0 },
      "targets": [
        { "expr": "kube_deployment_status_replicas_available{namespace=~\"inference|app|keda\"} / clamp_min(kube_deployment_spec_replicas{namespace=~\"inference|app|keda\"}, 1)", "legendFormat": "{{namespace}}/{{deployment}}", "refId": "A", "instant": true }
      ]
    },

    { "id": 74, "title": "API Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "slo:http_error_rate:ratio_rate5m or vector(0)", "legendFormat": "API error rate (SLO)", "refId": "A" },
        { "expr": "(sum(rate(istio_requests_total{destination_service=~\"inference-api.*\",response_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(istio_requests_total{destination_service=~\"inference-api.*\"}[5m])) or vector(1), 1)", "legendFormat": "API 5xx (Istio)", "refId": "B" }
      ]
    },

    { "id": 75, "title": "Ingress RPS — 유입 요청 수",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "#5794F2", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 12 } }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "sum(rate(istio_requests_total{destination_service=~\"inference-api.*\"}[1m]))", "legendFormat": "Ingress RPS (전체 유입)", "refId": "A" }
      ]
    },

    { "id": 76, "title": "추론 완료 TPS (메인)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "#73BF69", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 12 } }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "sum(rate(istio_requests_total{destination_service=~\"inference-api.*\",response_code=~\"2..\"}[1m]))", "legendFormat": "추론 완료 TPS (2xx)", "refId": "A" }
      ]
    },

    { "id": 78, "title": "최종 적재 TPS (보조)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "#F9934E", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "rate(kafka_consumergroup_current_offset{consumergroup=\"inference-worker\",topic=\"inference-request\"}[1m])", "legendFormat": "최종 적재 TPS (DB 완료)", "refId": "A" }
      ]
    },

    { "type": "row", "title": "🖥️ 인프라 상태 (EKS 노드 / Pod)", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }, "id": 10 },

    {
      "id": 11, "title": "Running Pods 수",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum(kube_pod_status_phase{phase=\"Running\",namespace=~\"$namespace\"})",
        "legendFormat": "Running",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },

    {
      "id": 12, "title": "Pod 재시작 (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m])) * 300",
        "legendFormat": "재시작 횟수",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 13, "title": "Prometheus 수집 대상 상태",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "count(up == 1)", "legendFormat": "Up", "refId": "A" },
        { "expr": "count(up == 0)", "legendFormat": "Down", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Down" },
            "properties": [{ "id": "thresholds", "value": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "horizontal" }
    },

    {
      "id": 14, "title": "노드 CPU 사용률",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sre:node_cpu_utilization:rate5m * 100",
        "legendFormat": "{{ instance }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 15, "title": "노드 메모리 사용률",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sre:node_memory_utilization:ratio * 100",
        "legendFormat": "{{ instance }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 16, "title": "Pod 재시작 현황 (네임스페이스별)",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum by (namespace, pod, container) (increase(kube_pod_container_status_restarts_total[1h])) > 0",
        "legendFormat": "{{ namespace }} / {{ pod }}",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "재시작 횟수 (1h)" },
              { "id": "thresholds", "value": { "mode": "absolute",
                "steps": [{ "color": "green", "value": null },
                          { "color": "yellow", "value": 1 },
                          { "color": "red", "value": 5 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]}
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "재시작 횟수 (1h)", "desc": true }]
      }
    },

    {
      "id": 17, "title": "Deployment 가용성",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sre:deployment_availability:ratio{namespace=~\"$namespace\"} * 100",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": false,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "pod": true,
              "service": true
            },
            "renameByName": {
              "namespace": "네임스페이스",
              "deployment": "Deployment",
              "Value": "가용성 %"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": {}
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "가용성 %" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute",
                "steps": [{ "color": "red", "value": null },
                          { "color": "yellow", "value": 50 },
                          { "color": "green", "value": 100 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]}
        ]
      },
      "options": { "filterable": true }
    },

    { "type": "row", "title": "Predictor / ML Pod Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 }, "id": 20,
      "panels": []
    },

    {
      "id": 21, "title": "Predictor RPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=~\"inference/pdm-predictor|.*pdm-predictor.*|.*predictor.*\"}[1m]))",
        "legendFormat": "Predictor RPS",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 0 } }
      }
    },

    {
      "id": 22, "title": "Predictor Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "(sum(rate(http_requests_total{job=~\"inference/pdm-predictor|.*pdm-predictor.*|.*predictor.*\",status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_requests_total{job=~\"inference/pdm-predictor|.*pdm-predictor.*|.*predictor.*\"}[5m])) or vector(1), 1)",
        "legendFormat": "Predictor 5xx",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute",
          "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } }
      }
    },

    {
      "id": 23, "title": "Predictor P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket{job=~\"inference/pdm-predictor|.*pdm-predictor.*|.*predictor.*\"}[5m])) by (le)) * 1000",
        "legendFormat": "Predictor P99",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "mode": "absolute",
          "steps": [{ "color": "green", "value": null },
                    { "color": "yellow", "value": 3000 },
                    { "color": "red", "value": 5000 }] } }
      }
    },

    { "type": "row", "title": "📨 Kafka / MSK 메트릭 (⑤ 김세원 연동 후 활성화)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 }, "id": 30,
      "panels": [
        {
          "id": 31, "title": "Consumer Lag — inference-request (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "kafka_consumergroup_lag{topic=\"inference-request\"}",
            "legendFormat": "{{ consumergroup }}",
            "refId": "A"
          }],
          "fieldConfig": {
            "defaults": { "unit": "short", "thresholds": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null },
                        { "color": "yellow", "value": 500 },
                        { "color": "red", "value": 1000 }] } }
          },
          "description": "Kafka Exporter 연동 후 활성화됩니다. (lagThreshold: 100)"
        },
        {
          "id": 32, "title": "DLQ 메시지 수 (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "sum(increase(kafka_topic_partition_current_offset{topic=~\".*dlq.*\"}[5m]))",
            "legendFormat": "DLQ 메시지 (5m)",
            "refId": "A"
          }],
          "fieldConfig": {
            "defaults": { "unit": "short", "thresholds": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
          }
        }
      ]
    },

    { "type": "row", "title": "🖧 노드 오토스케일링 (Cluster Autoscaler)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 }, "id": 60,
      "panels": []
    },

    {
      "id": 61, "title": "Ready 노드 수 (워크로드별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        {
          "expr": "count by (label_workload) (\n  kube_node_labels{label_workload=~\"inference|general\"}\n  * on(node) group_left()\n  kube_node_status_condition{condition=\"Ready\", status=\"true\"}\n)",
          "legendFormat": "{{ label_workload }}", "refId": "A"
        },
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "legendFormat": "전체", "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 62, "title": "Pending Pod 수 (CA 스케일아웃 트리거)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Pending\", namespace!~\"kube-system|monitoring\"}) or vector(0)",
          "legendFormat": "Pending Pods", "refId": "A"
        },
        {
          "expr": "cluster_autoscaler_unschedulable_pods_count or vector(0)",
          "legendFormat": "Unschedulable (CA 감지)", "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Unschedulable (CA 감지)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#ff1744", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },

    {
      "id": 63, "title": "CA 스케일링 이벤트 (30분 누적)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        {
          "expr": "increase(cluster_autoscaler_scaled_up_nodes_total[30m]) or vector(0)",
          "legendFormat": "스케일업 (노드 추가)", "refId": "A"
        },
        {
          "expr": "increase(cluster_autoscaler_scaled_down_nodes_total[30m]) or vector(0)",
          "legendFormat": "스케일다운 (노드 제거)", "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars", "barAlignment": 0 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "스케일업 (노드 추가)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#00e676", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "스케일다운 (노드 제거)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#ffd600", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] }
      }
    },

    { "type": "row", "title": "📈 KEDA 오토스케일링",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 63 }, "id": 40 },

    {
      "id": 41, "title": "Deployment 레플리카 수 (네임스페이스별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"}",
          "legendFormat": "{{ namespace }}/{{ deployment }}", "refId": "A" },
        { "expr": "kube_deployment_spec_replicas{namespace=~\"$namespace\"}",
          "legendFormat": "{{ deployment }} (목표)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 0 } },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [5, 5], "fill": "dash" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 42, "title": "HPA 현황",
      "type": "table",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"$namespace\"}",
        "legendFormat": "{{ namespace }}/{{ horizontalpodautoscaler }}",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "현재 레플리카" }] }
        ]
      }
    },

    { "type": "row", "title": "💥 Chaos Engineering 결과",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 72 }, "id": 50 },

    {
      "id": 51, "title": "Chaos 테스트 중 에러율 추이",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 73 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "slo:http_error_rate:ratio_rate5m * 100",
          "legendFormat": "HTTP 에러율 %", "refId": "A" },
        { "expr": "sum(rate(kube_pod_container_status_restarts_total[5m])) * 300",
          "legendFormat": "Pod 재시작율", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "description": "Chaos Mesh 장애 주입 시 이 패널로 SLO 영향도를 측정합니다."
    }

  ],

