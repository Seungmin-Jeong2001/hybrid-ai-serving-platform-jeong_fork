{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SRE 기반 비동기 AI 서빙 플랫폼 통합 모니터링 | 담당: 신민석",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "type": "row", "title": "🎯 SLO / Error Budget 현황", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1 },

    {
      "id": 2, "title": "서비스 가용성 (현재)",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 5, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "slo:service_availability:ratio * 100",
        "legendFormat": "가용성 %",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 99,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.5 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 3, "title": "Error Budget 잔여량",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 5, "x": 5, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "slo:error_budget_remaining:ratio * 100",
        "legendFormat": "잔여 %",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 4, "title": "Error Budget 번 레이트 (1h / 6h / 24h)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 14, "x": 10, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "slo:error_budget_burn_rate:1h", "legendFormat": "1h 번 레이트", "refId": "A" },
        { "expr": "slo:error_budget_burn_rate:6h", "legendFormat": "6h 번 레이트", "refId": "B" },
        { "expr": "slo:error_budget_burn_rate:24h", "legendFormat": "24h 번 레이트", "refId": "C" },
        { "expr": "vector(14.4)", "legendFormat": "Critical 임계값 (1h 소진)", "refId": "D" },
        { "expr": "vector(6)", "legendFormat": "Warning 임계값 (6h 소진)", "refId": "E" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical 임계값 (1h 소진)" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
                           { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Warning 임계값 (6h 소진)" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
                           { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "title": "🖥️ 인프라 상태 (EKS 노드 / Pod)", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }, "id": 10 },

    {
      "id": 11, "title": "Running Pods 수",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum(kube_pod_status_phase{phase=\"Running\",namespace=~\"$namespace\"})",
        "legendFormat": "Running",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },

    {
      "id": 12, "title": "Pod 재시작 (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m])) * 300",
        "legendFormat": "재시작 횟수",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 13, "title": "Prometheus 수집 대상 상태",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "count(up == 1)", "legendFormat": "Up", "refId": "A" },
        { "expr": "count(up == 0)", "legendFormat": "Down", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Down" },
            "properties": [{ "id": "thresholds", "value": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "horizontal" }
    },

    {
      "id": 14, "title": "노드 CPU 사용률",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sre:node_cpu_utilization:rate5m * 100",
        "legendFormat": "{{ instance }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 15, "title": "노드 메모리 사용률",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sre:node_memory_utilization:ratio * 100",
        "legendFormat": "{{ instance }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 16, "title": "Pod 재시작 현황 (네임스페이스별)",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sum by (namespace, pod, container) (increase(kube_pod_container_status_restarts_total[1h])) > 0",
        "legendFormat": "{{ namespace }} / {{ pod }}",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "재시작 횟수 (1h)" },
              { "id": "thresholds", "value": { "mode": "absolute",
                "steps": [{ "color": "green", "value": null },
                          { "color": "yellow", "value": 1 },
                          { "color": "red", "value": 5 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]}
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "재시작 횟수 (1h)", "desc": true }]
      }
    },

    {
      "id": 17, "title": "Deployment 가용성",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "sre:deployment_availability:ratio{namespace=~\"$namespace\"} * 100",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": false,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "pod": true,
              "service": true
            },
            "renameByName": {
              "namespace": "네임스페이스",
              "deployment": "Deployment",
              "Value": "가용성 %"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": {}
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "가용성 %" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute",
                "steps": [{ "color": "red", "value": null },
                          { "color": "yellow", "value": 50 },
                          { "color": "green", "value": 100 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]}
        ]
      },
      "options": { "filterable": true }
    },

    { "type": "row", "title": "🤖 추론 서버 메트릭 (② 안예원 + ④ 최호성 연동 후 활성화)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 20,
      "panels": [
        {
          "id": 21, "title": "HTTP 요청율 (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "sum(rate(bentoml_request_total[5m]))",
            "legendFormat": "요청/초",
            "refId": "A"
          }],
          "description": "BentoML 메트릭 연동 후 활성화됩니다."
        },
        {
          "id": 22, "title": "HTTP 5xx 에러율 (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "slo:http_error_rate:ratio_rate5m * 100",
            "legendFormat": "에러율 %",
            "refId": "A"
          }],
          "fieldConfig": {
            "defaults": { "unit": "percent", "thresholds": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } }
          }
        },
        {
          "id": 23, "title": "P99 레이턴시 (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "slo:http_latency_p99:5m",
            "legendFormat": "P99 레이턴시 (s)",
            "refId": "A"
          }],
          "fieldConfig": {
            "defaults": { "unit": "s", "thresholds": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null },
                        { "color": "yellow", "value": 3 },
                        { "color": "red", "value": 5 }] } }
          }
        }
      ]
    },

    { "type": "row", "title": "📨 Kafka / MSK 메트릭 (⑤ 김세원 연동 후 활성화)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "id": 30,
      "panels": [
        {
          "id": 31, "title": "Consumer Lag — inference-request (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "kafka_consumergroup_lag{topic=\"inference-request\"}",
            "legendFormat": "{{ consumergroup }}",
            "refId": "A"
          }],
          "fieldConfig": {
            "defaults": { "unit": "short", "thresholds": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null },
                        { "color": "yellow", "value": 500 },
                        { "color": "red", "value": 1000 }] } }
          },
          "description": "Kafka Exporter 연동 후 활성화됩니다. (lagThreshold: 100)"
        },
        {
          "id": 32, "title": "DLQ 메시지 수 (placeholder)",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
          "targets": [{
            "expr": "sum(increase(kafka_topic_partition_current_offset{topic=~\".*dlq.*\"}[5m]))",
            "legendFormat": "DLQ 메시지 (5m)",
            "refId": "A"
          }],
          "fieldConfig": {
            "defaults": { "unit": "short", "thresholds": { "mode": "absolute",
              "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
          }
        }
      ]
    },

    { "type": "row", "title": "📈 KEDA 오토스케일링",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }, "id": 40 },

    {
      "id": 41, "title": "Deployment 레플리카 수 (네임스페이스별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"}",
          "legendFormat": "{{ namespace }}/{{ deployment }}", "refId": "A" },
        { "expr": "kube_deployment_spec_replicas{namespace=~\"$namespace\"}",
          "legendFormat": "{{ deployment }} (목표)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [5, 5], "fill": "dash" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 42, "title": "HPA 현황",
      "type": "table",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [{
        "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"$namespace\"}",
        "legendFormat": "{{ namespace }}/{{ horizontalpodautoscaler }}",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "현재 레플리카" }] }
        ]
      }
    },

    { "type": "row", "title": "💥 Chaos Engineering 결과",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 }, "id": 50 },

    {
      "id": 51, "title": "Chaos 테스트 중 에러율 추이",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
      "targets": [
        { "expr": "slo:http_error_rate:ratio_rate5m * 100",
          "legendFormat": "HTTP 에러율 %", "refId": "A" },
        { "expr": "sum(rate(kube_pod_container_status_restarts_total[5m])) * 300",
          "legendFormat": "Pod 재시작율", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "description": "Chaos Mesh 장애 주입 시 이 패널로 SLO 영향도를 측정합니다."
    }

  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["sre", "platform", "ai-serving", "chaos-engineering"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus (Public)",
        "multi": false,
        "name": "DS_PUBLIC",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PUBLIC}" },
        "definition": "label_values(kube_pod_info, namespace)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "query": { "query": "label_values(kube_pod_info, namespace)", "refId": "A" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "SRE Platform Overview",
  "uid": "sre-platform-v1",
  "version": 1
}
